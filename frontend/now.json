{
  "version": 2,
  "name": "food-scraper",
  "build": {
    "env": {
      "GOOGLE_ANALYTICS_TRACKER_ID": "@food-scraper-google-analytics-tracker-id",
      "HOTJAR_HJID": "@food-scraper-hotjar-hjid",
      "HOTJAR_HJSV": "@food-scraper-hotjar-hjsv"
    }
  },
  "builds": [
    {
      "src": "/frontend/package.json",
      "use": "@now/next"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/index"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
